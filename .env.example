# Copy to .env and fill in values. Never commit .env.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# HTTP port for Express (use the same base URL in Postman, e.g. http://localhost:5000)
PORT=5000

# ---------------------------------------------------------------------------
# PostgreSQL (Sequelize)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grubpac
DB_USER=postgres
# Password for DB_USER (code reads process.env.DB_PASS)
DB_PASS=postgres

# ---------------------------------------------------------------------------
# JWT (auth)
# ---------------------------------------------------------------------------
# Secret for signing and verifying access tokens; use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Optional: Amazon S3 uploads
# ---------------------------------------------------------------------------
# If ALL five are set, teacher uploads go to S3 and content.file_path is a public URL.
# If any are missing, files are stored locally under uploads/
#
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
#
# Optional: public base URL (e.g. CloudFront). If omitted, URLs use virtual-hosted style:
# https://<bucket>.s3.<region>.amazonaws.com/<key>
# S3_PUBLIC_BASE_URL=https://dxxxxxxxxxx.cloudfront.net
