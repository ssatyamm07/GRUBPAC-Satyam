{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://grubpac-satyam.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://grubpac-satyam.onrender.com/uploads/$1"
    }
  ]
}
