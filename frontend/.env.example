# During `npm run dev`, the browser calls /api and /uploads on the Vite port; those
# requests are proxied to Express.
#
# By default the proxy uses PORT from the repo root `.env` (parent folder), e.g. 5006.
# Override here if the API URL is not http://127.0.0.1:$PORT:
# VITE_API_PROXY_TARGET=http://127.0.0.1:5006
#
# Optional: call the API directly from the browser (skip proxy). Requires CORS on the API.
# VITE_API_BASE=http://localhost:5006
